# .dockerignore — Files excluded from the Docker build context
#
# Keeping the build context lean means faster builds and smaller images.
# Critically: .env must never be baked into an image — secrets stay on the host.

# Version control
.git
.gitignore

# Python bytecode and caches
__pycache__
*.pyc
*.pyo
*.pyd
.Python

# Environment files — secrets must never enter the image
.env
.env.*
!.env.example

# Test and CI artifacts
.pytest_cache
.coverage
htmlcov/

# Python packaging artifacts
*.egg-info
dist/
build/
.eggs/

# Virtual environments
.venv
venv
env

# Editor and OS artifacts
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Claude agent files — not needed in the container
.claude/
