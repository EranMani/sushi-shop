# .env.example — All environment variables required by the Sushi Shop stack.
#
# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is in .gitignore.
# This file (with placeholder values only) IS committed and serves as documentation.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker-compose up

# ─── Database ─────────────────────────────────────────────────────────────────

# Async PostgreSQL connection URL for the application.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# asyncpg is the async driver required by SQLAlchemy's async engine.
DATABASE_URL=postgresql+asyncpg://sushi:sushi@db:5432/sushi

# Async PostgreSQL connection URL for the test suite.
# Points to the sushi_test database provided by docker-compose.test.yml.
# Port 5433 on the host maps to the test postgres container.
TEST_DATABASE_URL=postgresql+asyncpg://sushi:sushi@localhost:5433/sushi_test

# ─── Redis ────────────────────────────────────────────────────────────────────

# Redis connection URL — used as both the Celery broker and the menu/order cache.
# Redis is NOT the source of truth — Postgres is authoritative. Redis is cache only.
REDIS_URL=redis://redis:6379/0

# ─── LLM Provider ─────────────────────────────────────────────────────────────

# Which LLM provider the AI assistant uses. Accepted values: "anthropic" or "openai".
# This controls which langchain integration is loaded in the agent.
LLM_PROVIDER=anthropic

# Anthropic API key — required when LLM_PROVIDER=anthropic.
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API key — required when LLM_PROVIDER=openai.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ─── Application ──────────────────────────────────────────────────────────────

# Application environment. Controls logging verbosity and debug behaviour.
# Accepted values: "development", "staging", "production"
APP_ENV=development

# How long (in seconds) menu data is cached in Redis before a fresh Postgres query.
# Lower values mean fresher data but more DB load. Default: 300 (5 minutes).
CACHE_TTL_SECONDS=300
